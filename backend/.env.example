# ===== 数据库 =====
# 格式：mysql+pymysql://<用户名>:<密码>@<主机>:<端口>/<库名>?charset=utf8mb4
DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/openrobotservice?charset=utf8mb4

# ===== JWT =====
JWT_SECRET=change-me-to-a-random-long-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ===== 应用 =====
APP_ENV=dev
FRONTEND_BASE_URL=http://127.0.0.1:5173

# ===== 微信服务号（留空则进入开发降级模式）=====
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=
WECHAT_AES_KEY=
WECHAT_OAUTH_REDIRECT=https://your.domain/api/wechat/oauth/callback

# ===== 微信模板消息 ID =====
TPL_ASSIGN_ID=
TPL_COMMENT_ID=
TPL_ESCALATE_ID=
